                              id: lShapeSizes
                              partnumber: lShapeSizes
                              manufacturer: ''
                              manufacturerPartUrl: lShapeSizes4
                              name: lShapeSizes
                              Parameters:
                              - {name: FLD, default: ' IfElse( Height > 1.5 , (Depth
                                  - Base Thickness - BaseBendRad - CustomFlangeSize
                                  - NotchSize - PartsGap) , (Depth - Base Thickness
                                  - PartsGap)) - IfElse(Height > Depth, CoverBendRad,
                                  0)', displayName: FLD}
                              - {name: FLH, default: Height - Base Thickness - TabSize
                                  - NotchSize, displayName: FLH}
                              - {name: FLW, default: Base Width - 2 * TabSize - 2
                                  * NotchSize, displayName: FLW}
                              - {name: HoleOffsetD, default: 'IfElse(Depth > 18.,
                                  1.5, .25)', description: the distance from the edge
                                  of a horizontal flange to place a hole if not centered.,
                                displayName: HoleOffsetD}
                              - {name: HoleOffsetW, default: 'IfElse(Base Width >
                                  18., 1.5, .25)', description: the distance from
                                  the edge of a horizontal top flange to place a hole
                                  if not centered., displayName: HoleOffsetW}
                              - {name: Width Including Mounts, default: '0', description: unused,
                                displayName: Width Including Mounts}
                              - {name: ChassisFlangeHoleOffset, default: 'IfElse(Depth
                                  > 18., 1.5, .358)', description: the distance from
                                  the center of a hole on the chassis flanges to the
                                  front or rear of the enclosure., displayName: ChassisFlangeHoleOffset}
                              Parser:
                                id: lShapeOptions
                                partnumber: lShapeOptions
                                manufacturer: ''
                                manufacturerPartUrl: lShapeOptions
                                name: lShapeOptions
                                Parameters:
                                - {name: CoverMounts, default: '0', description: no
                                    mounting wings, displayName: CoverMounts, boolean: true}
                                - {name: Has Seam Welds, default: '0', description: mounting
                                    wings, template: true, displayName: Has Seam Welds,
                                  boolean: true}
                                Parser:
                                  id: lShapeOptions
                                  partnumber: lShapeOptions
                                  manufacturer: ''
                                  manufacturerPartUrl: lShapeOptions
                                  name: 0fcc79d2-9797-11f0-a341-d85ed30e8e68
                                  Parameters:
                                  - {name: sqrt3o2, default: '0.8660254037844386',
                                    description: sqrt(3)/2, displayName: sqrt3o2}
                                  - {name: CoverNut, default: small nut, displayName: CoverNut}
                                  - {name: isCopper, default: '"MetalType" CONTAINS
                                      STRING "Copper"', displayName: isCopper}
                                  - {name: CornerRad, default: '.05', description: the
                                      rounding of corners to prevent scratching, displayName: CornerRad}
                                  - {name: CoverScrew, default: 'IfElse(Cover Thickness
                                      > .081, small screw, small thin metal screw)',
                                    displayName: CoverScrew}
                                  - {name: CoverBendRad, default: CoverBendRad, displayName: CoverBendRad}
                                  Constraints:
                                  - {formula: 'IfElse(Base Width > 3.0, Height LEQ
                                      (Base Width - 2), 1)', message: 'For enclosures
                                      where the width is greater than 3" (76.2mm),
                                      the width must be greater than the height by
                                      at least 2" (50.8mm).'}
                                  - {formula: 'IfElse(Base Width LEQ 3.0, Height LEQ
                                      Base Width, 1)', message: 'For enclosures where
                                      the width is NOT greater than 3" (76.2mm), the
                                      width must NOT be greater than the height.'}
                                  - {formula: 'IfElse(Height<11, 1.0, 0.0)', message: Height
                                      must be less than 11" (279.4mm).}
