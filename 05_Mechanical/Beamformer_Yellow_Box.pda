                    manufacturerPartUrl: lShapeBaseMetal2
                    name: lShapeBaseMetal2
                    Parameters:
                    - {name: Base Color, default: '118', description: the color of
                        the base of the enclosure, template: true, displayName: Base
                        Color, units: MetalColor}
                    - {name: Base Thickness, default: 'IfElse("MetalType" CONTAINS
                        STRING "Aluminum", 14, IfElse("MetalType" CONTAINS STRING
                        "Copper",16, 18))', description: the thickness of the base
                        of the enclosure, template: true, displayName: Base Metal
                        Thickness, units: MetalThickness, unitDepends: MetalType}
                    Parser:
                      id: lShapeBaseMetal
                      partnumber: lShapeBaseMetal
                      manufacturer: ''
                      manufacturerPartUrl: lShapeBaseMetal2
                      name: lShapeBaseMetal
                      Parameters:
                      - {name: TD, default: WeldJigMetalThickness - Base Thickness,
                        description: the difference between the thickness of the welding
                          jig and the base part, displayName: TD}
                      - {name: JigBendRad, default: 'BiVariate(BendingRadii, WeldJigMetalThickness,
                          WeldJigMetalType)', description: the bend radius of the
                          jig, displayName: JigBendRad}
                      - {name: JigKFactor, default: '.5', description: the default
                          kfactor of the jig, displayName: JigKFactor}
                      - {name: BaseBendRad, default: 'BiVariate(BendingRadii, Base
                          Thickness, "MetalType")', description: the bend radius of
                          the base, displayName: BaseBendRad}
                      - {name: BaseKFactor, default: '.5', description: the default
                          kfactor of the base, displayName: BaseKFactor}
                      - {name: WeldJigMetalType, default: JigMetal(MetalType), description: The
                          Metal Type used, displayName: WeldJigMetalType}
                      - {name: WeldJigMetalThickness, default: 'JigThickness("MetalType",
