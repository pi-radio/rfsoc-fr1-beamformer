                            id: lShapeSizes4
                            partnumber: lShapeSizes4
                            manufacturer: ''
                            manufacturerPartUrl: lShapeSizes4
                            name: lShapeSizes4
                            Parameters:
                            - {name: Depth, default: '16.0', description: the depth
                                of the enclosure base, template: true, displayName: Depth,
                              min: '1', max: '50'}
                            - {name: Height, default: '8.0', description: the height
                                of the enclosure base, template: true, displayName: Height,
                              min: '.75', max: '24'}
                            - {name: TabSize, default: '.238', description: The length
                                of the tabs for the corners, displayName: TabSize}
                            - {name: Overhang, default: '.03', description: the overhang
                                for the cover, displayName: Overhang}
                            - {name: NotchSize, default: '.012', description: the
                                width of a Notch, displayName: NotchSize}
                            - {name: Base Width, default: '18.0', description: the
                                width of the enclosure base, template: true, displayName: Base
                                Width, min: '1', max: '50'}
                            - {name: HoleOffsetD, default: '.25', description: the
                                distance from the edge of a horizontal flange to place
                                a hole if not centered., displayName: HoleOffsetD}
                            - {name: HoleOffsetH, default: '.625', description: the
                                distance from the edge of a vertical flange to place
                                a hole if not centered., displayName: HoleOffsetH}
                            - {name: CustomFlangeSize, default: '.579', description: the
                                width of a flange, template: true, displayName: Flange
