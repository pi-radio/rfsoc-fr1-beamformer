    Parser:
      id: metalOptions4
      partnumber: metalOptions4
      manufacturer: ''
      manufacturerPartUrl: metalOptions4
      name: 8064dbb0-884b-4602-ac19-3fee1f5e0e76
      Parameters:
      - {name: Chem Film, default: '0', description: whether to use Chem Film treatment,
        template: true, displayName: Chemical Conversion Coating, boolean: true, displays: '"MetalType"
          CONTAINS STRING "Aluminum"'}
      - {name: Passivation, default: 'IfElse("MetalType" CONTAINS STRING "Stainless",
          1, 0)', description: whether to use Passivation treatment, displayName: Passivation,
        boolean: true, displays: 'false'}
      Warnings:
      - {formula: Chem Film, message: 'If using Chem Film treatment, Zinc fasteners
          must be placeable after bending to be compatible with Chem Film. This is
          hard to predict but generally may mean they must be further from the edges
          of the enclosure if inside the enclosure (room for tooling). It is recommended
          that you use stainless steel fasteners if using Chem Film.'}
      - {formula: Passivation, message: 'If using stainless steel, fasteners must
          be placeable after bending. This is hard to predict but generally may mean
          they must be further from the edges of the enclosure if inside the enclosure
          (room for tooling). It is recommended that you use stainless steel fasteners
          if using stainless steel.'}
      Parser:
        id: bracketMetal
        partnumber: bracketMetal
        manufacturer: ''
        manufacturerPartUrl: bracketMetal
        name: bracketMetal
        Parameters:
        - {name: Thickness, default: '11', description: the thickness of the metal,
          template: true, displayName: Metal Thickness, units: MetalThickness, unitDepends: MetalType}
        Parser:
          id: bracketMetal
          partnumber: bracketMetal
          manufacturer: ''
          manufacturerPartUrl: bracketMetal
          name: 2e9f2b7c-6ee3-11f0-8591-94e70bd6c7f3
          Parameters:
          - {name: KFactor, default: '.4', description: the ratio of the neutral radius
              to the thickness, displayName: KFactor}
          - {name: BracketBendRad, default: 'BiVariate(BendingRadii, Thickness, "MetalType")',
            description: the bend radius, displayName: BracketBendRad}
          Parser:
            id: L Bracket Parser
            partnumber: L Bracket Parser
            manufacturer: ''
            manufacturerPartUrl: bracketMetal
            name: L Bracket Parser
            Parameters:
            - {name: Depth, default: '6.0', description: the depth of the bracket,
              template: true, displayName: Depth, min: '1', max: '48'}
            - {name: Width, default: '6.0', description: 'the width of the bracket ',
              template: true, displayName: Width, min: '1', max: '48'}
            - {name: Height, default: '10.0', description: the height of the bracket,
              template: true, displayName: Height, min: '.5', max: '48'}
            - {name: sqrt3o2, default: '0.8660254037844386', description: sqrt(3)/2,
              displayName: sqrt3o2}
            - {name: InnerRadius, default: 'BiVariate(BendingRadii, Thickness, "MetalType")',
              description: the bend radius, displayName: InnerRadius}
            - {name: BaseCornerRad, default: FrontCornerRad, description: the radius
                of the corners on the base, template: true, displayName: Base Corner
                Radius, min: '0.05', max: (Depth / 2) - 0.01}
            - {name: FrontCornerRad, default: '.1', description: the radius of the
                corners on the front, template: true, displayName: Front Corner Radius,
              min: '0.05', max: (Depth / 2) - 0.01}
            - {name: dimLinePerpDistance, default: '0.75', description: Value used
                for the perp point of the dimension lines on the viewThing2Ds, displayName: dimLinePerpDistance}
    InlineFormulas:
    - {name: SteelBendingRadii, variable: metalThick, formula: 'IfElse(metalThick
        < .119,IfElse(metalThick < .104,IfElse(metalThick < .089,IfElse(metalThick
        < .074,IfElse(metalThick < .059,IfElse(metalThick < .047,IfElse(metalThick
        < .035,IfElse(metalThick < .029,.070,.065),.065),.075),.07),.06),.085),.08),.075)'}
    - {name: GalvaneelBendingRadii, variable: metalThick, formula: 'IfElse(metalThick
        < .077,IfElse(metalThick < .062,IfElse(metalThick < .051,IfElse(metalThick
        < .039,IfElse(metalThick < .033,.070,.065),.065),.075),.070),.060)'}
    - {name: StainlessBendingRadii, variable: metalThick, formula: 'IfElse(metalThick
        < .124,IfElse(metalThick < .077,IfElse(metalThick < .061,IfElse(metalThick
        < .049,IfElse(metalThick < .036,IfElse(metalThick < .030,.043,.090),.090),.070),.075),.060),.09)'}
    - {name: AluminumBendingRadii, variable: metalThick, formula: 'IfElse(metalThick
        < .124,IfElse(metalThick < .090,IfElse(metalThick < .080,IfElse(metalThick
        < .063,IfElse(metalThick < .050,IfElse(metalThick < .039,.020,.020),.020),.025),.030),.028),.030)'}
    - {variable1: metalThick, variable2: metalType, name: BendingRadii, formula: 'IfElse(metalType
        CONTAINS STRING "Cold Rolled", MonoVariate(SteelBendingRadii, metalThick),
        IfElse(metalType CONTAINS STRING "Galvaneel",MonoVariate(GalvaneelBendingRadii,
        metalThick), IfElse(metalType CONTAINS STRING "Stainless",MonoVariate(StainlessBendingRadii,
        metalThick),MonoVariate(AluminumBendingRadii, metalThick))))'}
